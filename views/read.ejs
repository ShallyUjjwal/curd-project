<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body>
    <div class="w-full min-h-screen bg-zinc-800  p-10 text-white">
         <div class="nav mb-5">
            <a  class="text-zinc-300" href="/">back to main</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">all users</h1>
        
        <div class="users flex gap-5 flex-wrap">
            <% if (users.length > 0) { %>
            <% users.forEach(user => { %>
<div class="user max-w-72 p-4  rounded-lg bg-gray-700">
    
             <img  class="w-full h-52 object-cover object-top rounded" src="<%= user.imageurl%>" alt="">
                <div class="w-full h-20  bg-red-600 rounded"></div>
                <h3 class = "text-xl font-bold mt-2"><%= user.name %></h3>
                <h5 class="text-gray-300"><%= user.email %></h5>
               <div class="flex gap-3 mt-10">
                <a class= "text-zinc-300" href="/edit/<%= user._id %>">edit user</a>
                <a class= "text-red-500" href="/delete/<%= user._id %>"> delete user</a>
               </div>
            
            </div>
                <% }) %>
            
         <% } else { %>
            <h3 class="text-zinc=300">No users found.</h3>
         <% }   %>

        </div>
    </div>
</body>
</html>